# 允许常用 git 读操作
prefix_rule(
    pattern = ["git"],
    decision = "allow",
    justification = "Allow safe git inspection commands",
)

# 允许 rtk 全部子命令；更安全的做法是只列出你真的需要的子命令
prefix_rule(
    pattern = ["rtk"],
    decision = "allow",
    justification = "Allow rtk commands in this trusted workspace",
)
